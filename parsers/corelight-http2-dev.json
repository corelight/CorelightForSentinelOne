{
    attributes: {
      "dataSource.category": "security",
      "dataSource.name": "Corelight",
      "dataSource.vendor": "Corelight",
      "category_uid": 4,
      "category_name": "Network Activity",
      "class_uid": 4002,
      "class_name": "HTTP Activity",
      "severity_id": 1,
      //"severity": "Informational",
      "metadata.product.name": "Corelight",
      "metadata.product.vendor_name": "Corelight",
      "metadata.version": "1.1.0",
      "app_name": "Corelight",
      "activity_id": 0
    },
    formats: [
      {
        format: "${parse=dottedJson}$",
        repeat: true
        rewrites: [
          {
            input: "_path",
            output: "metadata.log_name",
            match: ".*",
            replace: "$0"
          }, {
            input: "severity.name",
            output: "severity",
            match: "(\\w+).*",
            replace: "$1",
            outputIfNoMatch: false
          }, {
            input: "ts",
            output: "timestamp",
            match: ".*",
            replace: "$0"
          }, {
            input: "ts",
            output: "time",
            match: ".*",
            replace: "$0"
          }, {
            input: "uid",
            output: "metadata.uid",
            match: ".*",
            replace: "$0"
          }, {
            input: "uid",
            output: "uuid",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_uid",
            output: "agent.uuid",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_name",
            output: "endpoint.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_h",
            output: "src_endpoint.ip",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_p",
            output: "src_endpoint.port",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_uid",
            output: "src_endpoint.uid",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_name",
            output: "src_endpoint.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_h",
            output: "dst_endpoint.ip",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_p",
            output: "dst_endpoint.port",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_ep_uid",
            output: "dst_endpoint.uid",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_ep_name",
            output: "dst_endpoint.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.vlan",
            output: "dst_endpoint.vlan_uid",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.inner_vlan",
            output: "src_endpoint.vlan_uid",
            match: ".*",
            replace: "$0"
          }, {
            input: "method",
            output: "activity_id",
            match: "CONNECT",
            replace: 1
          }, {
            input: "method",
            output: "type_uid",
            match: "CONNECT",
            replace: 400201
          }, {
            input: "method",
            output: "activity_id",
            match: "DELETE",
            replace: 2
          }, {
            input: "method",
            output: "type_uid",
            match: "DELETE",
            replace: 400202
          }, {
            input: "method",
            output: "activity_id",
            match: "GET",
            replace: 3
          }, {
            input: "method",
            output: "type_uid",
            match: "GET",
            replace: 400203
          }, {
            input: "method",
            output: "activity_id",
            match: "HEAD",
            replace: 4
          }, {
            input: "method",
            output: "type_uid",
            match: "HEAD",
            replace: 400204
          }, {
            input: "method",
            output: "activity_id",
            match: "OPTIONS",
            replace: 5
          }, {
            input: "method",
            output: "type_uid",
            match: "OPTIONS",
            replace: 400205
          },{
            input: "method",
            output: "activity_id",
            match: "POST",
            replace: 6
          }, {
            input: "method",
            output: "type_uid",
            match: "POST",
            replace: 400206
          }, {
            input: "method",
            output: "activity_id",
            match: "PUT",
            replace: 7
          }, {
            input: "method",
            output: "type_uid",
            match: "PUT",
            replace: 400207
          }, {
            input: "method",
            output: "activity_id",
            match: "TRACE",
            replace: 8
          }, {
            input: "method",
            output: "type_uid",
            match: "TRACE",
            replace: 400208
          }, {
            input: "method",
            output: "activity_name",
            match: ".*",
            replace: "$0"
          }, {
            input: "method",
            output: "http_request.http_method",
            match: ".*",
            replace: "$0"
          }, {
            input: "host",
            output: "device.hostname",
            match: ".*",
            replace: "$0"
          }, {
            input: "uri",
            output: "http_request.url.url_string",
            match: ".*",
            replace: "$0"
          }, {
            input: "referrer",
            output: "http_request.referrer",
            match: ".*",
            replace: "$0"
          }, {
            input: "version",
            output: "metadata.version",
            match: ".*",
            replace: "$0"
          }, {
            input: "user_agent",
            output: "http_request.user_agent",
            match: ".*",
            replace: "$0"
          }, {
            input: "origin",
            output: "http_request.x_forwarded_for",
            match: ".*",
            replace: "$0"
          }, {
            input: "request_body_len",
            output: "http_request.length",
            match: ".*",
            replace: "$0"
          }, {
            input: "response_body_len",
            output: "http_response.length",
            match: ".*",
            replace: "$0"
          }, {
            input: "status_code",
            output: "http_response.code",
            match: ".*",
            replace: "$0"
          }, {
            input: "status_msg",
            output: "http_response.message",
            match: ".*",
            replace: "$0"
          }, {
            input: "tags",
            output: "metadata.labels",
            match: ".*",
            replace: "$0"
          }, {
            input: "username",
            output: "actor.user.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "proxied",
            output: "proxy_http_request.http_headers[0].value",
            match: ".*",
            replace: "$0"
          }, {
            input: "proxied",
            output: "proxy_http_request.http_headers[0].name",
            match: ".*",
            replace: "proxied"
          },{
            input: "client_header_names",
            output: "http_request.http_header.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "cookie_vars",
            output: "http_cookie.name",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_type",
            output: "endpoint.type",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_ostype",
            output: "endpoint.os",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_type",
            output: "src_endpoint.type",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.orig_ep_ostype",
            output: "src_endpoint.os",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_ep_type",
            output: "dst_endpoint.type",
            match: ".*",
            replace: "$0"
          }, {
            input: "id.resp_ep_ostype",
            output: "dst_endpoint.os",
            match: ".*",
            replace: "$0"
          }
        ]
      }
    ]
  }
  